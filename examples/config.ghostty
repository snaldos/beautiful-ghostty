# The installer adds this block to the existing Ghostty config. The absolute
# path is generated for the selected config directory; do not copy this example
# literally when XDG_CONFIG_HOME differs from ~/.config.

# BEGIN beautiful-ghostty
# Generated shader state; rerun install.sh to update this path.
config-file = ?~/.config/ghostty/beautiful-ghostty/active.ghostty
# END beautiful-ghostty
